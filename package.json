{
  "name": "secure-node-app",
  "version": "1.0.0",
  "description": "Secure Node.js application with CI/CD pipeline",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "lint": "eslint .",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "docs:validate": "node -e \"const fs=require('fs'); JSON.parse(fs.readFileSync('src/openapi.json','utf8')); console.log('OpenAPI spec is valid JSON');\"",
    "security:audit": "npm audit --audit-level=high",
    "security:snyk": "snyk test",
    "security:snyk:docker": "snyk container test secure-node-app:latest",
    "security:ossindex": "npx auditjs ossi",
    "security:lint": "eslint . --plugin security --config-lookup",
    "security:all": "npm run security:audit && npm run security:snyk && npm run security:lint",
    "docker:build": "docker build -t secure-node-app:latest .",
    "docker:scan": "npm run docker:build && npm run security:snyk:docker"
  },
  "keywords": [
    "security",
    "node",
    "express",
    "docker",
    "devsecops"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "audit-ci": "^6.6.1",
    "eslint": "^9.27.0",
    "eslint-plugin-security": "^2.1.1",
    "jest": "^29.7.0",
    "snyk": "^1.1221.0",
    "supertest": "^7.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
