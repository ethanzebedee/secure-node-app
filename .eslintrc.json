{
  "env": {
    "node": true,
    "es6": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:security/recommended"
  ],
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "plugins": [
    "security"
  ],
  "rules": {
    "no-console": "off",
    "strict": ["error", "global"]
  }
}

